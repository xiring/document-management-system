# PostgreSQL (SQLAlchemy URL)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/dms

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local uploads
UPLOAD_DIR=./uploads

# Ethereum / Polygon — leave empty to run without on-chain notarization
ETH_RPC_URL=
PRIVATE_KEY=
CONTRACT_ADDRESS=
CHAIN_ID=1
