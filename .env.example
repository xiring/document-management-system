# PostgreSQL (SQLAlchemy URL)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/dms

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local uploads
UPLOAD_DIR=./uploads

# Optional: first registration with this exact email becomes admin (case-insensitive)
BOOTSTRAP_ADMIN_EMAIL=

# Optional: set retention_expires_at on new uploads to now + N days (UTC). Omit or 0 to disable.
DEFAULT_RETENTION_DAYS=

# Ethereum / Polygon — leave empty to run without on-chain notarization
ETH_RPC_URL=
PRIVATE_KEY=
CONTRACT_ADDRESS=
CHAIN_ID=1
# Optional: global BatchNotary.sol (same chain as above) for periodic Merkle roots
BATCH_CONTRACT_ADDRESS=

# Public verify links (GET /public/verify?t=...) — prefer a dedicated secret in production
PUBLIC_VERIFY_SECRET=
PUBLIC_VERIFY_TOKEN_HOURS=168
